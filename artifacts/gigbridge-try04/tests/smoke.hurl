# ===== Auth =====

# Register (client)
POST {{host}}/users/register
Content-Type: application/json
{
  "email": "client@test.com",
  "name": "test_string",
  "password": "Password1234!",
  "role": "client"
}

HTTP 201
[Asserts]
jsonpath "$.user" exists

# Login (client)
POST {{host}}/users/login
Content-Type: application/json
{
  "email": "client@test.com",
  "password": "Password1234!"
}

HTTP 200
[Captures]
token_client: jsonpath "$.access_token"
[Asserts]
jsonpath "$.access_token" exists

