# ===== Auth =====

# Register
POST {{host}}/auth/register
Content-Type: application/json
{
  "email": "test@test.com",
  "org_name": "test_string",
  "password": "Password1234!"
}

HTTP 200
[Asserts]
jsonpath "$.access_token" exists

# Login
POST {{host}}/auth/login
Content-Type: application/json
{
  "email": "test@test.com",
  "password": "Password1234!"
}

HTTP 200
[Captures]
token: jsonpath "$.access_token"
[Asserts]
jsonpath "$.access_token" exists


# ===== Workflows =====

# CreateWorkflow
POST {{host}}/workflows
Authorization: Bearer {{token}}
Content-Type: application/json
{
  "title": "test_string",
  "trigger_event": "test_string"
}

HTTP 200
[Captures]
workflow_id: jsonpath "$.workflow.id"
[Asserts]
jsonpath "$.workflow" exists

# ActivateWorkflow
POST {{host}}/workflows/{{workflow_id}}/activate
Authorization: Bearer {{token}}

HTTP 200
[Asserts]
jsonpath "$.workflow" exists

# AddAction
POST {{host}}/workflows/{{workflow_id}}/actions
Authorization: Bearer {{token}}
Content-Type: application/json
{
  "action_type": "test_string",
  "payload_template": "test_string",
  "sequence_order": 1
}

HTTP 200
[Captures]
action_id: jsonpath "$.action.id"
[Asserts]
jsonpath "$.action" exists

# PauseWorkflow
POST {{host}}/workflows/{{workflow_id}}/pause
Authorization: Bearer {{token}}

HTTP 200
[Asserts]
jsonpath "$.workflow" exists


# ===== ExecutionLogs =====

