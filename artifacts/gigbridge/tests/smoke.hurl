# ===== Auth =====

# Register
POST {{host}}/auth/register
Content-Type: application/json
{
  "email": "test_string",
  "name": "test_string",
  "password": "Password1234!",
  "role": "test_string"
}

HTTP 200
[Asserts]
jsonpath "$.user" exists

# Login
POST {{host}}/auth/login
Content-Type: application/json
{
  "email": "test_string",
  "password": "Password1234!"
}

HTTP 200
[Captures]
token: jsonpath "$.token"
[Asserts]
jsonpath "$.token" exists


# ===== Gigs =====

# CreateGig
POST {{host}}/gigs
Authorization: Bearer {{token}}
Content-Type: application/json
{
  "budget": 1,
  "description": "test_string",
  "title": "test_string"
}

HTTP 200
[Captures]
gig_id: jsonpath "$.gig.id"
[Asserts]
jsonpath "$.gig" exists

# PublishGig
PUT {{host}}/gigs/{{gig_id}}/publish
Authorization: Bearer {{token}}

HTTP 200
[Asserts]
jsonpath "$.gig" exists

# SubmitProposal
POST {{host}}/gigs/{{gig_id}}/proposals
Authorization: Bearer {{token}}
Content-Type: application/json
{
  "bid_amount": 10000
}

HTTP 200
[Captures]
proposal_id: jsonpath "$.proposal.id"
[Asserts]
jsonpath "$.proposal" exists


# ===== Proposals =====

# AcceptProposal
POST {{host}}/proposals/{{proposal_id}}/accept
Authorization: Bearer {{token}}

HTTP 200
[Asserts]
jsonpath "$.gig" exists
jsonpath "$.proposal" exists


